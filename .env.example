# =============================================================================
# Synthesis Workbench — Environment Configuration
# =============================================================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local
#
# Required variables are marked [REQUIRED]. Everything else has sensible defaults.
#
# Quick start with all services:
#   pnpm dev:services
# This launches Next.js (:3000), Foundry bridge (:4466), and Stage1 bridge (:3200).
# =============================================================================

# -----------------------------------------------------------------------------
# LLM Backend: Anthropic (Cloud)
# -----------------------------------------------------------------------------

# [REQUIRED] Your Anthropic API key
ANTHROPIC_API_KEY="sk-ant-api03-YOUR_KEY_HERE"

# Anthropic API base URL (default: https://api.anthropic.com)
ANTHROPIC_BASE_URL="https://api.anthropic.com"

# Model to use for chat (default: claude-opus-4-5-20251101)
ANTHROPIC_MODEL="claude-opus-4-5-20251101"

# Auto-derived: set to "true" when ANTHROPIC_API_KEY is present.
# You can override to "true" to force-enable Anthropic in the browser.
# NEXT_PUBLIC_ANTHROPIC_ENABLED="true"

# -----------------------------------------------------------------------------
# LLM Backend: Ollama (Local) — Optional
# -----------------------------------------------------------------------------
# Uncomment to use a local Ollama instance instead of / alongside Anthropic.

# OLLAMA_BASE_URL="http://localhost:11434"
# OLLAMA_MODEL="llama3"

# -----------------------------------------------------------------------------
# MCP Services
# -----------------------------------------------------------------------------

# OODS Foundry MCP — renders components, validates schemas, builds tokens.
# [REQUIRED for /render, /validate, and token building]
# Start the OODS MCP bridge first, then set this URL.
# Recommended endpoint: bridge /run route.
OODS_FOUNDRY_MCP_URL="http://127.0.0.1:4466/run"

# Stage1 Inspector MCP — lists runs, retrieves artifacts.
# [OPTIONAL] Uncomment if you have the Stage1 MCP bridge running locally.
# Without this, bundle loading uses file-system bundles in stage1_out/.
# NEXT_PUBLIC_STAGE1_MCP_URL is exposed to browser (triggers /api/stage1/mcp proxy).
# STAGE1_MCP_URL is server-side only (used by the proxy route to reach upstream).
# NEXT_PUBLIC_STAGE1_MCP_URL="http://127.0.0.1:3200/mcp"
# STAGE1_MCP_URL="http://127.0.0.1:3200/mcp"

# -----------------------------------------------------------------------------
# Project Identity
# -----------------------------------------------------------------------------

# CMOS project identifier for mission tracking (optional)
CMOS_PROJECT_ID="synthesis-workbench"
