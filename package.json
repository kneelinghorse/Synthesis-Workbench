{
  "name": "synthesis-workbench",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "verify:foundry-templates": "npx tsx scripts/verify-foundry-templates.ts",
    "verify:foundry-fragments": "npx tsx scripts/verify-foundry-fragment-contract.ts --require-live",
    "verify:foundry-fragments:fixtures": "npx tsx scripts/verify-foundry-fragment-contract.ts --fixtures-only",
    "test:adapters": "vitest run src/lib/runtime/adapters/anthropic.test.ts src/lib/runtime/adapters/ollama.test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ci": "CI=true playwright test",
    "test:e2e:headed": "playwright test --headed",
    "dev:foundry": "cd ../OODS-Forge/packages/mcp-bridge && MCP_BRIDGE_PORT=4466 pnpm dev",
    "dev:stage1": "cd ../Stage1/packages/mcp-bridge && PORT=3200 pnpm dev",
    "dev:services": "node scripts/dev-services.js"
  },
  "dependencies": {
    "@assistant-ui/react": "0.11.53",
    "@assistant-ui/react-markdown": "0.11.9",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-slot": "^1.2.4",
    "@xyflow/react": "^12.11.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "js-yaml": "^4.1.1",
    "lucide-react": "^0.562.0",
    "next": "^15.5.9",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "zod": "^4.3.5",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "^15.5.9",
    "jsdom": "^28.0.0",
    "tailwindcss": "^4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5",
    "vitest": "^4.0.16"
  }
}
